# Hack Club AI proxy key (required for LLM ensemble)
HACKCLUB_API_KEY=sk-hc-v1-...

# MongoDB Atlas connection string (required for persistent stats & recent scans)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.z4scab1.mongodb.net/?appName=Cluster0

# Allowed CORS origins (comma-separated, optional — defaults to localhost ports)
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Google OAuth for Safe Mails (required for "Connect with Google" button)
# Create at console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client
# Enable: Gmail API. Authorized redirect URI: https://your-backend/api/safe-mails/callback
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=https://phishingo-production.up.railway.app/api/safe-mails/callback
FRONTEND_URL=https://phishingo-zk3c.vercel.app

# WhatsApp Cloud API — Meta's free official API (no Twilio needed)
# Setup: developers.facebook.com → My Apps → Create App → Business → Add WhatsApp
# Then: WhatsApp → Getting Started → copy Phone Number ID and Access Token
# Free tier: 1,000 conversations/month free
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx
